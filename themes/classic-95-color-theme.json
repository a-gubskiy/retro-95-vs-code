  "tokenColors": [
    {
      "name": "Text",
      "scope": [
        "source",
        "text",
        "variable",
        "punctuation.definition"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#808080",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords and storage",
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#000080",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#008000"
      }
    },
    {
      "name": "Numbers, constants, and language constants",
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#0000FF"
      }
    },
    {
      "name": "Types and classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#008080",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions and methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Parameters and properties",
      "scope": [
        "variable.parameter",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#800000"
      }
    },
    {
      "name": "Markup headings",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#000080",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#000080",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markup quotes",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#808080",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#008000"
      }
    },
    {
      "name": "Diff deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#800000"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#000080"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#000080",
    "class": {
      "foreground": "#008080",
      "bold": true
    },
    "enum": "#008080",
    "interface": "#008080",
    "struct": "#008080",
    "typeParameter": "#008080",
    "type": "#008080",
    "parameter": "#000000",
    "variable": "#000000",
    "property": "#000000",
    "function": "#000000",
    "method": "#000000",
    "macro": "#800080",
    "keyword": {
      "foreground": "#000080",
      "bold": true
    },
    "comment": {
      "foreground": "#808080",
      "italic": true
    },
    "string": "#008000",
    "number": "#0000FF",
    "regexp": "#800080",
    "operator": "#000000"
  }
}
